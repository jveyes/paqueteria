# =============================================================================
# CONFIGURACIÓN DE LA APLICACIÓN
# =============================================================================

# Configuración de la aplicación
APP_NAME=Sistema de Paquetería v1.1
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=8000

# Clave secreta para JWT y encriptación
SECRET_KEY=your_super_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# BASE DE DATOS
# =============================================================================

# URL de conexión a MySQL
DATABASE_URL=mysql+pymysql://paqueteria_user:paqueteria_pass@localhost:3306/paqueteria

# Configuración de pool de conexiones
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# =============================================================================
# LIWA SMS API (Colombia)
# =============================================================================

# Credenciales de LIWA SMS
LIWA_API_KEY=your_liwa_api_key_here
LIWA_API_URL=https://apidoc.liwa.co/
LIWA_SENDER=PAQUETERIA

# Configuración de SMS
SMS_ENABLED=True
SMS_RETRY_ATTEMPTS=3
SMS_TIMEOUT=30

# =============================================================================
# AWS S3 CONFIGURACIÓN
# =============================================================================

# Credenciales de AWS
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# Configuración del bucket S3
S3_BUCKET_NAME=paqueteria-files
S3_ENDPOINT_URL=https://s3.amazonaws.com

# Configuración de archivos
MAX_FILE_SIZE=10485760  # 10MB en bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf
UPLOAD_FOLDER=uploads

# =============================================================================
# WHATSAPP BUSINESS API (Opcional)
# =============================================================================

# Configuración de WhatsApp
WHATSAPP_ENABLED=False
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_API_URL=https://graph.facebook.com/v17.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# =============================================================================
# SEGURIDAD Y RATE LIMITING
# =============================================================================

# Rate limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "https://paquetes.papyrus.com.co"]
CORS_ALLOW_CREDENTIALS=True

# =============================================================================
# LOGGING
# =============================================================================

# Configuración de logs
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log

# =============================================================================
# MONITOREO Y HEALTH CHECKS
# =============================================================================

# Health checks
HEALTH_CHECK_ENABLED=True
HEALTH_CHECK_INTERVAL=30

# Métricas
METRICS_ENABLED=False
PROMETHEUS_ENABLED=False

# =============================================================================
# CACHE (Opcional)
# =============================================================================

# Redis para cache
REDIS_ENABLED=False
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# =============================================================================
# BACKGROUND TASKS (Opcional)
# =============================================================================

# Celery para tareas en segundo plano
CELERY_ENABLED=False
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# CONFIGURACIÓN DE EMAIL (Opcional)
# =============================================================================

# SMTP para emails
EMAIL_ENABLED=False
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# =============================================================================
# CONFIGURACIÓN DE PAGOS (Futuro)
# =============================================================================

# Integración con pasarelas de pago
PAYMENT_ENABLED=False
PAYMENT_GATEWAY=stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# =============================================================================
# CONFIGURACIÓN DE NOTIFICACIONES
# =============================================================================

# Configuración de notificaciones push
PUSH_NOTIFICATIONS_ENABLED=False
FIREBASE_CREDENTIALS_PATH=path/to/firebase-credentials.json

# =============================================================================
# CONFIGURACIÓN DE BACKUP
# =============================================================================

# Backup automático
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *  # Diario a las 2 AM
BACKUP_RETENTION_DAYS=7

# =============================================================================
# CONFIGURACIÓN DE DESARROLLO
# =============================================================================

# Configuraciones específicas para desarrollo
if DEBUG:
    # Logs más detallados en desarrollo
    LOG_LEVEL=DEBUG
    
    # CORS más permisivo en desarrollo
    CORS_ORIGINS=["*"]
    
    # Rate limiting más permisivo en desarrollo
    RATE_LIMIT_REQUESTS_PER_MINUTE=1000
    RATE_LIMIT_REQUESTS_PER_HOUR=10000
