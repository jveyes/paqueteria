# =============================================================================
# VARIABLES DE ENTORNO - PRODUCCIÓN
# Sistema de Paquetería v1.1
# =============================================================================

# =============================================================================
# CONFIGURACIÓN DE LA APLICACIÓN
# =============================================================================
APP_NAME=Sistema de Paquetería v1.1
APP_VERSION=1.1.0
DEBUG=False
ENVIRONMENT=production
SECRET_KEY=your-super-secret-production-key-change-this-immediately
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,www.your-domain.com

# =============================================================================
# BASE DE DATOS
# =============================================================================
DATABASE_URL=mysql+pymysql://paqueteria_user:paqueteria_strong_password_2024@mysql:3306/paqueteria
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# =============================================================================
# SERVIDOR
# =============================================================================
HOST=0.0.0.0
PORT=8000
WORKERS=4
WORKER_CLASS=uvicorn.workers.UvicornWorker
BIND=0.0.0.0:8000

# =============================================================================
# CORS Y SEGURIDAD
# =============================================================================
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With

# =============================================================================
# LIWA SMS API (Colombia)
# =============================================================================
LIWA_API_KEY=your_liwa_api_key_here
LIWA_API_URL=https://api.liwa.co/sms
LIWA_SENDER_ID=PAQUETERIA

# =============================================================================
# AWS S3
# =============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=paqueteria-files-production
S3_ENDPOINT_URL=https://s3.amazonaws.com

# =============================================================================
# EMAIL
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=True
SMTP_SSL=False

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/app.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# =============================================================================
# ARCHIVOS
# =============================================================================
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# =============================================================================
# CACHE
# =============================================================================
CACHE_URL=redis://redis:6379/0
CACHE_TTL=3600

# =============================================================================
# MONITORING
# =============================================================================
SENTRY_DSN=your_sentry_dsn_here
HEALTH_CHECK_ENABLED=True
METRICS_ENABLED=True

# =============================================================================
# BACKUP
# =============================================================================
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=paqueteria-backups

# =============================================================================
# SSL/TLS
# =============================================================================
SSL_ENABLED=True
SSL_CERT_PATH=/app/ssl/cert.pem
SSL_KEY_PATH=/app/ssl/key.pem
SSL_CA_PATH=/app/ssl/ca.pem

# =============================================================================
# NGINX
# =============================================================================
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024
NGINX_CLIENT_MAX_BODY_SIZE=10M
NGINX_PROXY_READ_TIMEOUT=60
NGINX_PROXY_SEND_TIMEOUT=60

# =============================================================================
# MYSQL
# =============================================================================
MYSQL_ROOT_PASSWORD=super_secure_root_password_change_this
MYSQL_DATABASE=paqueteria
MYSQL_USER=paqueteria_user
MYSQL_PASSWORD=paqueteria_strong_password_2024
MYSQL_CHARACTER_SET_SERVER=utf8mb4
MYSQL_COLLATION_SERVER=utf8mb4_unicode_ci

# =============================================================================
# REDIS (para cache y sesiones)
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password_here

# =============================================================================
# NOTIFICACIONES
# =============================================================================
NOTIFICATION_EMAIL_ENABLED=True
NOTIFICATION_SMS_ENABLED=True
NOTIFICATION_WEBHOOK_ENABLED=False
NOTIFICATION_WEBHOOK_URL=

# =============================================================================
# DESARROLLO Y DEBUG
# =============================================================================
RELOAD=False
ACCESS_LOG=True
ERROR_LOG=True
PROFILING_ENABLED=False
